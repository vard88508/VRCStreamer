SERVER_NAME=Self-Hosted Instance
SERVER_DESCRIPTION=
ROOT_REDIRECT_URL=https://stream.vard.cc

BIND_ADDR=0.0.0.0:443
TLS_CERT_PATH=/etc/letsencrypt/live/example.com/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/example.com/privkey.pem

RTSP_BIND_ADDR=0.0.0.0:554
RTSP_PUBLIC_BASE=none

ALLOWED_ORIGINS=https://stream.vard.cc
ALLOW_ANY_ORIGIN=false
PASSWORD=

VIDEO=true
AVAILABLE_VIDEO_QUALITY=1280x720*30/2000,1280x720*60/4000,1920x1080*30/3000,1920x1080*60/6000
MAX_H264_FRAME_BYTES=524288
VIDEO_INGEST_BURST_SECS=2

MAX_CONNECTIONS=320
MAX_STREAMERS=0
MAX_STREAMERS_PER_IP=3
MAX_LISTENERS_TOTAL=0
MAX_LISTENERS_PER_STREAM=105
MAX_LISTENERS_PER_IP=6
EGRESS_KBPS_PER_LISTENER=384

MAX_HTTP_REQUESTS_PER_IP=60
HTTP_RATE_LIMIT_WINDOW_SECS=60

MAX_RTSP_REQUESTS_PER_CONNECTION=4096
RTSP_HANDSHAKE_TIMEOUT_SECS=30

CHANNEL_BUFFER=128
STREAMER_IDLE_TIMEOUT_SECS=120

RUST_LOG=warn
